<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <!-- Local Drift rows can be reconciled after the user explicitly logs in. -->
        <include domain="database" path="." />
        <!-- The database include is an allowlist; credentials and preferences are excluded. -->
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <!-- The database include is an allowlist; credentials and preferences are excluded. -->
    </device-transfer>
</data-extraction-rules>
